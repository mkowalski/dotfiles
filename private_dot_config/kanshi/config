# kanshi - automatic display profile switching (replaces autorandr)
#
# IMPORTANT: Output names (DP-3, HDMI-1, etc.) may differ between X11 and
# Wayland, or change between reboots depending on which USB-C/TB port is used.
#
# For reliable matching, replace output names with description patterns:
#   output "Dell Inc. DELL U4025QW *" mode 5120x2160@120Hz ...
#
# Run 'swaymsg -t get_outputs' to find exact names and descriptions.
#
# Profiles translated from autorandr configs in ~/.config/autorandr/

# Laptop only (default fallback)
profile default {
    output eDP-1 mode 2240x1400@60Hz position 0,0
    output DP-3 disable
    output DP-5 disable
    output DP-6 disable
}

profile laptop-only {
    output eDP-1 enable mode 2240x1400@60.021Hz position 0,0
}

# # Home - Dell U4025QW ultrawide, lid closed
# profile home-lid-closed {
